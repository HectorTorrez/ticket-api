# Copy to .env — never commit real secrets

NODE_ENV=development
PORT=3001

# Required — app will not start without these
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ticket_api?schema=public"
JWT_ACCESS_SECRET="replace-with-at-least-32-characters-secret-key!!"
JWT_REFRESH_SECRET="replace-with-another-32-characters-secret-key!"

# Optional — defaults shown
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
ORDER_RESERVATION_TTL_MINUTES=15
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_BASE_URL=http://localhost:3000

# Optional — S3 event banners (code is ready; leave empty for local dev without uploads)
# Without S3_BUCKET, banner upload returns 503; everything else works.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=

# Optional — only used by `pnpm exec prisma db seed`
SEED_ADMIN_EMAIL=admin@ticket-api.local
SEED_ADMIN_PASSWORD=Admin123!ChangeMe

# Not implemented yet (future): real PSP, email/SES, ticket PDFs in S3, Redis for Socket.IO scaling
